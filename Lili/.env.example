APP_NAME=Lili
LOG_LEVEL=INFO

INPUT_DEVICE_INDEX=
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_BLOCKSIZE=1280

WAKEWORD_FALLBACK_MODEL=tiny
WAKEWORD_FALLBACK_DEVICE=cpu
WAKEWORD_FALLBACK_COMPUTE_TYPE=int8
WAKEWORD_FALLBACK_LANGUAGE=pt
WAKEWORD_FALLBACK_BEAM_SIZE=1
WAKEWORD_FALLBACK_VAD_THRESHOLD=0.02
WAKEWORD_FALLBACK_MIN_DURATION_MS=300
WAKEWORD_FALLBACK_MAX_DURATION_MS=1200
WAKEWORD_FALLBACK_SILENCE_TIMEOUT_MS=400
WAKEWORD_FALLBACK_COOLDOWN_MS=1500

COMMAND_SILENCE_TIMEOUT_MS=1500
COMMAND_MAX_DURATION_MS=8000
COMMAND_MIN_DURATION_MS=500
COMMAND_VAD_THRESHOLD=0.02

STT_PROVIDER=openai_whisper
STT_MOCK_TEXT=ligar a luz da sala
STT_MODEL=small
STT_MODEL_DOWNLOAD_ROOT=models/whisper
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=pt
STT_BEAM_SIZE=1

CHAT_PROVIDER=ollama
CHAT_MOCK_RESPONSE_PREFIX=Resposta mock para:
CHAT_BASE_URL=http://localhost:11434
CHAT_MODEL=qwen2.5:7b-instruct
CHAT_TIMEOUT_SECONDS=60

TTS_PROVIDER=pyttsx3
TTS_RATE=180
TTS_VOLUME=1.0
WAKEWORD_PHRASES=computador
